{
  "manifest_version": 3,
  "name": "NotebookLM Directory Manager",
  "version": "1.0",
  "description": "为 NotebookLM 提供目录管理功能",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://notebooklm.google.com/*"
      ],
      "css": [
        "styles/main.css"
      ],
      "js": [
        "scripts/storage.js",
        "scripts/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://notebooklm.google.com/*"
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}